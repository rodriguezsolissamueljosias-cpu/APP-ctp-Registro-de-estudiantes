{
  "version": 2,
  "buildCommand": "npm run install-deps && npm run build-frontend",
  "outputDirectory": "ctp-platanar-frontend/build",
  "installCommand": "npm install",
  "builds": [
    {
      "src": "ctp-platanar-frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    },
    {
      "src": "ctp-platanar-backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "ctp-platanar-backend/server.js" },
    { "source": "/health", "destination": "ctp-platanar-backend/server.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
