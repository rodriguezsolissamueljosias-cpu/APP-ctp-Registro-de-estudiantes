DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=ctp_platanar
DB_DIALECT=mysql
PORT=5000
NODE_ENV=development
JWT_SECRET=your_secret_key_here

# Para despliegues en la nube puedes usar DATABASE_URL en lugar de DB_HOST/DB_USER/DB_PASSWORD/DB_NAME:
# DATABASE_URL=mysql://user:password@host:3306/ctp_platanar
# DATABASE_URL=postgres://user:password@host:5432/ctp_platanar
# Si tu proveedor requiere SSL:
# DB_SSL=true
